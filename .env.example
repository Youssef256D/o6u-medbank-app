# Frontend-safe values (can be public in browser code)
# Browser code in this project uses Supabase Data APIs through supabase-js.
# Use the project URL + publishable/anon key here. Do not use a database connection string in the browser.
# If you invoke Supabase Edge Functions directly with verify_jwt = true, also provide the legacy anon key below.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_LEGACY_ANON_KEY=

# Server-only value (must stay secret). Use either variable name:
# Current server endpoints in this repo call Supabase Auth/Admin REST APIs with the service role key.
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SECRET_KEY=

# Optional Postgres connection strings for tooling or future backend workers.
# Choose the right mode based on Supabase guidance:
# - Direct: migrations, pg_dump, database GUIs, long-lived IPv6-capable hosts
# - Session pooler: long-lived IPv4 hosts that cannot use direct IPv6
# - Transaction pooler: serverless / short-lived compute, and disable prepared statements there
SUPABASE_DB_DIRECT_URL=
SUPABASE_DB_SESSION_POOLER_URL=
SUPABASE_DB_TRANSACTION_POOLER_URL=

# Optional aliases accepted by server helpers:
# NEXT_PUBLIC_SUPABASE_URL=
# PUBLIC_SUPABASE_URL=

# Optional for cross-origin frontend -> API calls (comma-separated).
# Examples:
# ALLOWED_ORIGIN=https://your-app.vercel.app
# ALLOWED_ORIGIN=https://youssef256d.github.io,https://your-app.vercel.app
ALLOWED_ORIGIN=*
